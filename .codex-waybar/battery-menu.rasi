/**
 * Experimental Plasma-like battery popup for niri/waybar.
 * Focuses on structure: battery summary + power profiles + charge limit toggle.
 */

* {
    main-bg:            rgba(24, 26, 38, 0.94);
    main-fg:            #cdd6f4ff;
    main-br:            rgba(180, 190, 254, 0.85);
    panel-bg:           rgba(17, 17, 27, 0.90);
    summary-bg:         rgba(36, 40, 58, 0.86);
    select-bg:          rgba(180, 190, 254, 0.94);
    select-fg:          #11111bff;
    muted-fg:           rgba(205, 214, 244, 0.72);
}

configuration {
    modi:                        "drun";
    show-icons:                  false;
    kb-accept-entry:             "Return,KP_Enter";
    kb-cancel:                   "Escape,MouseSecondary";
    me-select-entry:             "";
    me-accept-entry:             "MousePrimary";
    click-to-exit:               true;
    hover-select:                true;
}

window {
    width:                       22em;
    height:                      19em;
    transparency:                "real";
    border:                      1px;
    border-color:                @main-br;
    border-radius:               18px;
    background-color:            transparent;
    padding:                     0em;
}

mainbox {
    enabled:                     true;
    orientation:                 vertical;
    spacing:                     0.45em;
    padding:                     0.55em;
    children:                    [ "message", "listbox" ];
    background-color:            transparent;
}

message {
    enabled:                     true;
    padding:                     0.95em 1.05em;
    border-radius:               14px;
    background-color:            @summary-bg;
    text-color:                  @main-fg;
}

textbox {
    background-color:            transparent;
    text-color:                  inherit;
    vertical-align:              0.5;
    horizontal-align:            0.0;
    highlight:                   none;
    placeholder:                 false;
}

listbox {
    spacing:                     0em;
    padding:                     0em;
    orientation:                 vertical;
    children:                    [ "listview" ];
    background-color:            @panel-bg;
    border-radius:               14px;
}

listview {
    enabled:                     true;
    padding:                     0.5em 0.55em 0.55em 0.55em;
    columns:                     1;
    lines:                       4;
    cycle:                       true;
    fixed-height:                true;
    expand:                      false;
    scrollbar:                   false;
    background-color:            transparent;
    text-color:                  @main-fg;
}

element {
    enabled:                     true;
    padding:                     0.72em 0.82em;
    cursor:                      pointer;
    border-radius:               10px;
    background-color:            rgba(255, 255, 255, 0.02);
    text-color:                  @main-fg;
}

element selected.normal {
    background-color:            @select-bg;
    text-color:                  @select-fg;
}

element-text {
    vertical-align:              0.5;
    horizontal-align:            0.0;
    background-color:            transparent;
    text-color:                  inherit;
}
