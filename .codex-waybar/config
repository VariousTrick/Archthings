{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 0,
  "reload_style_on_change": true,
  "modules-left": [
    "custom/distro",
    "custom/left_div#1",
    "niri/workspaces",
    "custom/right_div#1",
    "niri/window"
  ],
  "modules-center": [
    "cpu",
    "custom/left_div#2",
    "memory",
    "custom/left_div#3",
    "idle_inhibitor",
    "clock#time",
    "custom/right_div#2",
    "clock#date",
    "custom/right_div#3",
    "network"
  ],
  "modules-right": [
    "pulseaudio",
    "custom/left_div#4",
    "battery",
    "custom/left_inv#1",
    "custom/power"
  ],
  "custom/distro": {
    "format": "NIRI",
    "tooltip": false
  },
  "custom/left_div#1": {
    "format": "",
    "tooltip": false
  },
  "custom/right_div#1": {
    "format": "",
    "tooltip": false
  },
  "custom/left_div#2": {
    "format": "",
    "tooltip": false
  },
  "custom/left_div#3": {
    "format": "",
    "tooltip": false
  },
  "custom/right_div#2": {
    "format": "",
    "tooltip": false
  },
  "custom/right_div#3": {
    "format": "",
    "tooltip": false
  },
  "custom/left_div#4": {
    "format": "",
    "tooltip": false
  },
  "custom/left_inv#1": {
    "format": "",
    "tooltip": false
  },
  "custom/power": {
    "format": "LOCK",
    "on-click": "swaylock",
    "tooltip-format": "Lock screen"
  },
  "niri/workspaces": {
    "format": "{value}",
    "all-outputs": false
  },
  "niri/window": {
    "format": "{}",
    "icon": false,
    "separate-outputs": true,
    "expand": true
  },
  "cpu": {
    "interval": 2,
    "format": "CPU {usage}%",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "memory": {
    "interval": 5,
    "format": "MEM {}%",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "idle_inhibitor": {
    "format": "AWAKE",
    "format-deactivated": "IDLE"
  },
  "clock#time": {
    "format": "{:%H:%M}"
  },
  "clock#date": {
    "format": "{:%Y-%m-%d}"
  },
  "network": {
    "format-wifi": "NET {essid} {signalStrength}%",
    "format-ethernet": "ETH {ipaddr}",
    "format-linked": "NET link",
    "format-disconnected": "NET down",
    "tooltip-format": "{ifname} {ipaddr}/{cidr}"
  },
  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "VOL muted",
    "scroll-step": 5
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "BAT {capacity}%",
    "format-charging": "BAT+ {capacity}%",
    "format-plugged": "AC {capacity}%"
  }
}
